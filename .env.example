# Resend API key for transactional email.
# Get it from Resend Dashboard > API Keys.
RESEND_API_KEY=

# Resend webhook signing secret for verifying delivery/open/bounce webhooks.
# Get it after creating the webhook in Resend Dashboard > Webhooks.
RESEND_WEBHOOK_SECRET=

# Verified sender address used for outgoing emails.
# Get/set this in Resend Dashboard after verifying the sender domain.
# Example: Allianz Shield Plus <noreply@asp.finnomalaysia.com>
RESEND_FROM_ADDRESS=

# Senang Pay merchant ID for checkout/payment redirect generation.
# Get it from your Senang Pay merchant dashboard/API settings.
SENANGPAY_MERCHANT_ID=

# Senang Pay secret key for payment request/callback hash verification.
# Get it from your Senang Pay merchant dashboard/API settings.
SENANGPAY_SECRET=

# Senang Pay mode for payment URL generation.
# Use sandbox for testing; production later uses the live endpoint.
SENANGPAY_MODE=sandbox

# Private random pepper used to HMAC-hash NRIC values before Firestore writes.
# Generate once and keep secret. Example command: openssl rand -hex 32
NRIC_HASH_PEPPER=

# Public base URL used when generating customer tracker links in emails.
# Local web app: http://localhost:3000
# Production: https://asp.finnomalaysia.com
TRACKER_BASE_URL=https://asp.finnomalaysia.com

# Firebase/GCP project ID.
# Get it from Firebase Console > Project settings, or GCP Console project selector.
FIREBASE_PROJECT_ID=asp-finno

# Public Firebase web app config used by the CRM login screen.
# Get it from Firebase Console > Project settings > Your apps > Web app > SDK setup and configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=asp-finno.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=asp-finno
NEXT_PUBLIC_FIREBASE_APP_ID=1:626165683486:web:db393188205ff9548a250f

# Optional analytics IDs. Leave blank until you create the properties/pixels.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Only set these when using Firebase emulators instead of ADC/real Firestore.
# For ADC mode, leave them blank in .env.local.
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
